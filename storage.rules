rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // All media — public reads, admin writes
    match /{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
