rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Portfolio content — public reads, admin writes
    match /artworks/{docId} {
      allow read: if true;
      allow write: if isAdmin();

      match /gallery/{galleryId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /series/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /techniques/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /contents/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Internal data — admin only
    match /commissions/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
